                <div style="display:inline-block;margin-top: 30px">@Html.Raw(ViewBag.CTO_Error)</div>
            }
            @using (Html.BeginForm("CRMImport", "Dataimport", FormMethod.Post, new
            {
                enctype = "multipart/form-data"
            }))
            {
                <div style="display:inline-block;margin-top: 30px;margin-left:50px"><input class="mainbutton" type="submit" value="CRM Import" /></div>
                <div style="display:inline-block;margin-top: 30px">@Html.Raw(ViewBag.CRM_Error)</div>
            }
            @using (Html.BeginForm("GeteSowData", "Dataimport", FormMethod.Post, new
            {
                enctype = "multipart/form-data"
            }))
            {
                <div style="display:inline-block;margin-top: 30px;margin-left:50px"><input class="mainbutton" type="submit" value="Get eSOW & import to DB" /></div>
                <div class="alert alert-danger">
                    <strong>Error:</strong> @Html.Raw(ViewBag.eSowApiError)
                </div>
            }
            @using (Html.BeginForm("SendReportsUpdatedSummary", "Dataimport", FormMethod.Post, new
            {
                enctype = "multipart/form-data"
            }))
            {
                <div style="display:inline-block;margin-top: 30px;margin-left:50px"><input class="mainbutton" type="submit" value="Send Report Updated Summary" /></div>
                <div style="display:inline-block;margin-top: 30px">@Html.Raw(ViewBag.Summary_Error)</div>
            }
        </div>
    </div>
