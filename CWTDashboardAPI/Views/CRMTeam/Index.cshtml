@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>ExcelImporting</title>
    <style>
        .split {
            height : 100%;
            width: 50%;
            position: fixed;
            z-index: 1;
            top: 0;
            overflow-x: hidden;
            padding-top: 20px;
        }

        .left {
            left: 0;
        }

        .right {
            right: 0;
        }
        .labeltext {
            font-size: 15px;
            font-weight: bold;
            font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;
            margin : 5px 0px 5px 0px;
            padding-top: 10px
            display: inline-block;
        }
        .labeltextheader {
            font-size: 19px;
            font-weight: bold;
            font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;
            margin: 5px 0px 5px 0px;
            padding-top: 10px;
            display: inline-block;
        }
        .choosefile {
            width: 230px;
            display: inline-block;
            margin-right: 10px;
        }
        .buttonstyle {
            /*background-color: #FF684B;*/
            /*padding: 16px 32px;*/
            width: 70px;
            text-align: center;
            /*text-decoration: none;*/
            font-size: 13px;
            height: 27px;
            transition-duration: 0.4s;
            cursor: pointer;
            background-color: white;
            color: white;
            border: 2px solid #FF684B;
            background-color: #FF684B;
            border-radius: 5px;
        }
        .buttonstyle:hover {
            border-radius: 5px;
            background-color: white;
            border: 2px solid #FF684B;
            color: black;
        }
        .mainbutton {
            width: 150px;
            border-radius: 5px;
            text-align: center;
            /*text-decoration: none;*/
            font-size: 13px;
            height: 27px;
            cursor: pointer;
            background-color: #FF684B;
            border: 2px solid #FF684B;
            color: white;
        }
    </style>
</head>
<body>
    <div class="split left">
        <div style="margin: 10px 0px 15px 70px;">
            <div style="width: 100%;padding-left: 50px">
                <label class="labeltextheader" style="display:inline-block"> Click on Below Button to Download the CLR Report</label>
            </div>
            @using (Html.BeginForm("GetCLRData", "CRMTeam", FormMethod.Post, new
            {
                enctype = "multipart/form-data"
            }))
            {
                <div style="display:inline-block;margin-top: 30px;margin-left:50px"><input class="mainbutton" type="submit" value="Get CLR" /></div>
                <div style="display:inline-block;margin-top: 30px">@Html.Raw(ViewBag.Error1)</div>
            }
        </div>
    </div>
</body>
</html>